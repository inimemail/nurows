# Backend listen port
PORT=38471

# Optional: backend listen host
HOST=0.0.0.0

# Runtime mode
NODE_ENV=production

# SQLite database path used by the server and Docker deployment
SQLITE_DB_PATH=/app/data/app.db

# Vite dev server port
VITE_DEV_SERVER_PORT=5173

# Optional: override local dev API / WS proxy targets
VITE_API_PROXY_TARGET=http://localhost:38471
VITE_WS_PROXY_TARGET=ws://localhost:38471
